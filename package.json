    "eslint": "^9.39.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.7.0",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.8"
  }
