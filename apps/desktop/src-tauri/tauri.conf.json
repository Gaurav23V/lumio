{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lumio",
  "version": "0.1.0",
  "identifier": "app.lumio.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lumio",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:lumio.db"]
    }
  }
}
