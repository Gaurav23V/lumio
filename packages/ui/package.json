{
  "name": "@lumio/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./library": { "types": "./dist/library-only.d.ts", "default": "./dist/library-only.js" }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --project integration"
  },
  "dependencies": {
    "@lumio/core": "workspace:*",
    "epubjs": "^0.3.93",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3"
  }
}
